{
  "name": "pylon-mcp",
  "version": "1.0.0",
  "description": "MCP server exposing the full Pylon API — all 114 endpoints auto-generated from Pylon's OpenAPI spec, including knowledge base CRUD that the hosted MCP doesn't cover.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pylon-mcp": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Carter-S/pylon-mcp.git"
  },
  "homepage": "https://github.com/Carter-S/pylon-mcp",
  "bugs": "https://github.com/Carter-S/pylon-mcp/issues",
  "license": "MIT",
  "author": "Carter Springall",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pylon",
    "claude",
    "anthropic",
    "ai",
    "support",
    "knowledge-base"
  ],
  "scripts": {
    "build": "tsc && cp src/openapi.json dist/openapi.json && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
